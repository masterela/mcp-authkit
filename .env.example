# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=localhost
SERVER_PORT=8005

# ── Primary IdP — Keycloak ────────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8888/realms/mcp-poc5
KEYCLOAK_PRIMARY_CLIENT_ID=mcp-poc5-vscode

# ── GitHub OAuth App (secondary leg) ─────────────────────────────────────────
# Create at https://github.com/settings/developers → OAuth Apps → New OAuth App
# Authorization callback URL: http://localhost:8005/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ── Token / credential storage ────────────────────────────────────────────────
# memory  — in-process dict, zero config, state lost on restart (default)
# file    — Fernet-encrypted JSON files, suitable for shared-filesystem replicas
#           (e.g. multiple uvicorn workers, EFS-mounted pods)
# redis   — Fernet-encrypted values in Redis, for distributed / cloud deployments
TOKEN_STORAGE_MODE=memory

# ── Encryption key (required for file and redis modes) ───────────────────────
# Provide exactly ONE of the two options; leave both empty for memory mode.
#
# Option A — inline base64 Fernet key (44 chars):
#   Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
STORAGE_ENCRYPTION_KEY=

# Option B — path to a file whose first line is the base64 key.
#   Point at a path managed by AWS Secrets Manager, HashiCorp Vault agent,
#   or another KMS to enable key rotation without redeployment.
STORAGE_ENCRYPTION_KEY_PATH=

# ── File storage (TOKEN_STORAGE_MODE=file) ────────────────────────────────────
FILE_STORAGE_PATH=/tmp/mcp-auth-store

# ── Redis storage (TOKEN_STORAGE_MODE=redis) ─────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=mcp:auth:

# ── TLS / CA bundle (optional — needed behind corporate MITM proxies) ─────────
# REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
# SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
